{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AppSettings": {
    "DatabasePath": "backups.sqlite",
    "MaxConcurrentBackups": 3,
    "BackupTimeoutSeconds": 3600,
    "ScheduleCheckIntervalSeconds": 60,
    "EnableVerificationByDefault": true,
    "EnableS3StorageByDefault": false,
    "LogLevel": "Information",
    "RetentionDays": 30,
    "MaxBackupCount": 10,
    "LocalStoragePath": "backups",
    "CompressBackups": false,
    "NotificationEmails": [],
    "HealthCheckStatusFilePath": "health-status.json",
    "HealthCheckGraceFactor": 1.5
  }
}
